#!/usr/bin/env bash
set -euo pipefail

files=()

while IFS= read -r -d '' file; do
  files+=("$file")
done < <(
  git diff --cached --name-only -z --diff-filter=ACMR -- \
    '*.sh' \
    '.githooks/*'
)

if [[ ${#files[@]} -eq 0 ]]; then
  exit 0
fi

for tool in shfmt shellcheck; do
  if ! command -v "$tool" >/dev/null 2>&1; then
    echo "Required tool is not installed: $tool" >&2
    exit 1
  fi
done

for file in "${files[@]}"; do
  if ! git diff --quiet -- "$file"; then
    echo "Cannot auto-format a partially staged file: $file" >&2
    echo "Stage or stash its remaining changes before committing." >&2
    exit 1
  fi
done

shfmt -w -i 2 -ci "${files[@]}"
shellcheck "${files[@]}"

git add -- "${files[@]}"
